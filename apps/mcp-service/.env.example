# PostgREST base URL.
# The service calls anon RPCs (login, issue_api_key) here, and per-user
# RPCs/views with the user's x-api-key. Dev: http://localhost:4444
POSTGREST_URL=http://localhost:4444

# Image service base URL (POST <base>/upload). Leave empty to disable the
# upload_image tool. Dev image service: http://localhost:4446
IMAGE_SERVICE_URL=http://localhost:4446

# Public issuer / base URL of THIS MCP service. It is the OAuth issuer and the
# token audience is <MCP_ISSUER_URL>/mcp. Dev: http://localhost:4008
MCP_ISSUER_URL=http://localhost:4008

# HS256 secret for the service's OWN OAuth access/refresh tokens (>= 32 chars).
# Distinct from the app's JWT_SECRET and POSTGREST_JWT_SECRET. This service
# never holds the PostgREST signing secret.
MCP_TOKEN_SECRET=

# AES-256-GCM key used to encrypt per-user PostgREST API keys at rest.
# 32 bytes, supplied as 64 hex chars OR base64. Generate:
#   openssl rand -hex 32
MCP_ENCRYPTION_KEY=

# SQLite store path (OAuth clients, auth codes, refresh-token families,
# encrypted per-user keys). Prod: /opt/matrummet/data/mcp.sqlite
SQLITE_PATH=data/mcp.sqlite

# HTTP port
PORT=4008

# Optional token lifetimes
# MCP_ACCESS_TOKEN_TTL=1h
# MCP_REFRESH_TOKEN_TTL_DAYS=30
